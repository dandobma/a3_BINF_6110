.Rproj.user
.Rhistory
.RData
.Ruserdata

# R / RStudio
.Rhistory
.RData
.Ruserdata
*.Rproj.user/

# OS files
.DS_Store
Thumbs.db

# Ignore raw sequencing data
data/raw/*

# Allow processed results (small files)
!data/processed/
!data/processed/**

# Still ignore huge file types
*.fastq
*.fastq.gz
*.bam
*.sam

# Keep folder structure but not files
!data/raw/.gitkeep
!data/processed/.gitkeep

# Large sequencing files
*.fastq
*.fastq.gz
*.fq
*.bam
*.sam

# Kraken / Bracken outputs (can be huge)
*.kraken
*.report
*.bracken

# Temporary / logs
*.log
tmp/